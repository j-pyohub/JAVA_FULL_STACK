	public Collection<VisitorsVO> getVisitorsDate(String inDate) {
		Collection<VisitorsVO> list = new ArrayList<>();
		String sql = "select visitor_no_seq, member_id, contents, in_date from visitors where in_date = to_date(?, 'YYYY-MM-DD') and del_flag is null";
