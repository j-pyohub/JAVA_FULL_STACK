	public boolean writeVisitors(String memberId, String contents) {
		boolean result = false;
		String sql = "insert into visitors (visitor_no_seq, member_id, contents, in_date) values (visitor_no_seq.nextval, ?, ?, sysdate)";
		try{
			PreparedStatement pstmt = conn.prepareStatement(sql);
			pstmt.setString(1, memberId);
			pstmt.setString(2, contents);
			result = pstmt.executeUpdate() == 1;
			pstmt.close();
		} catch(SQLException e){
			e.printStackTrace();
		}
			
		return result;
	}

	public boolean editVisitors(String contents, int visitorNoSeq) {
		boolean result = false;
		String sql = "update visitors set contents = ?, up_date = sysdate where visitor_no_seq = ?";
		try{
			PreparedStatement pstmt = conn.prepareStatement(sql);
			pstmt.setString(1, contents);
			pstmt.setInt(2, visitorNoSeq);
			result = pstmt.executeUpdate() == 1;
			pstmt.close();
		} catch(SQLException e){
			e.printStackTrace();
		}
		return result;
	}

	public boolean deleteVisitors(int visitorNoSeq) {
		boolean result = false;
		String sql = "update visitors set del_flag = sysdate where visitor_no_seq = ?";
		try{
			PreparedStatement pstmt = conn.prepareStatement(sql);
			pstmt.setInt(1, visitorNoSeq);
			result = pstmt.executeUpdate() == 1;
			pstmt.close();
		} catch(SQLException e){
			e.printStackTrace();
		}
		return result;
	}

	public Collection<VisitorsVO> getVisitorsName(String name) {
		Collection<VisitorsVO> list = new ArrayList<>();
		String sql = "select visitor_no_seq, member_id, contents, in_date from visitors where member_id"
				+ " in (select member_id from members where name like '%' || ? || '%') and del_flag is null";
		try{
			PreparedStatement pstmt = conn.prepareStatement(sql);
			pstmt.setString(1, name);
			ResultSet rs = pstmt.executeQuery();
			while(rs.next())
				list.add(new VisitorsVO(rs.getInt(1), rs.getString(2), rs.getString(3), rs.getDate(4)));
		} catch(SQLException e){
			e.printStackTrace();
		}
		return list;
	}

	public Collection<VisitorsVO> getVisitorsContents(String contents) {
		Collection<VisitorsVO> list = new ArrayList<>();
		String sql = "select visitor_no_seq, member_id, contents, in_date from visitors where contents like '%' || ? || '%' and del_flag is null";
