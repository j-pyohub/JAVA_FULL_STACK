		String sql = "update visitors set contents = ?, up_date = sysdate where visitor_no_seq = ?";
		try{
			PreparedStatement pstmt = conn.prepareStatement(sql);
			pstmt.setString(1, contents);
			pstmt.setInt(2, visitorNoSeq);
