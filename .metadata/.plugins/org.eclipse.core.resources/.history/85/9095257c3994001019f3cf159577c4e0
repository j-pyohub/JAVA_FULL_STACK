package com.oopsw.servlet;

import java.io.IOException;
import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import com.oopsw.action.Action;
import com.oopsw.action.ActionFactory;

/**
 * Servlet implementation class FrontControllerServlet
 */
@WebServlet("/controller") //쓰고 싶은 대로 쓰ㅓ로ㅜㅏ
public class FrontControllerServlet extends HttpServlet {

	protected void service(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		//모든 요청을 처리 /controller?cmd=addMemberUI (->지금은 포폴용이라 가독성 좋게 디렉토리. 나중에 인코딩하면 됨)
		try { //동기 통신
			System.out.println("5초 대기");
			Thread.sleep(5000); //5초 멈춤
		} catch (InterruptedException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
		
		
		
		request.setCharacterEncoding("utf-8");
		
		String cmd = request.getParameter("cmd");
		if (cmd==null || cmd.trim().length()==0)
			cmd = "mainUI";
		
		//일할 Action 찾아 온다.
		Action action = ActionFactory.getAction(cmd);
		
		//결과 페이지로 이동한다.
		String url = action.execute(request);
		request.getRequestDispatcher("/"+url).forward(request, response);
	}
}
