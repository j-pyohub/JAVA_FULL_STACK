package com.oopsw.model;

import java.sql.Date;

public class VisitorsVO {
	private int visitorsNoSeq;
	private String contents;
	private Date inDate;
	
	
	public VisitorsVO(){}
	
	public VisitorsVO(int visitorsNoSeq, String contents, Date inDate) {
		setVisitorsNoSeq(visitorsNoSeq);
		setContents(contents);
		setInDate(inDate);
	}

	
	
	public int getVisitorsNoSeq() {
		return visitorsNoSeq;
	}

	public void setVisitorsNoSeq(int visitorsNoSeq) {
		this.visitorsNoSeq = visitorsNoSeq;
	}

	public String getContents() {
		return contents;
	}

	public void setContents(String contents) {
		this.contents = contents;
	}

	public Date getInDate() {
		return inDate;
	}

	public void setInDate(Date inDate) {
		this.inDate = inDate;
	}

	@Override
	public String toString() {
		return "VisitorsVO [contents=" + contents + ", inDate=" + inDate + "]";
	}

	
	

	
}
