<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="memberMapper">
	<select id="selectLogin" parameterType="com.oopsw.model.MemberVO" resultType="String">
		select name from members where member_id = #{memberId} and pw = #{pw}
	</select>
	<insert id="addMember" parameterType="com.oopsw.model.MemberVO">
		insert into members(member_id, pw, name, in_date inDate) values (#{memberId, #{pw}, #{name}, sysdate)
	</insert>
	
	<select id = "getVisitors" resultMap="java.util.HashMap"]>
		select visitor_no_seq visitorNoSeq, member_id memberId, contents, in_date inDate from visitors order by visitor_no_seq desc
	</select>
</mapper>
